# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Replace with your MongoDB Atlas URI or local MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/devfeed-bot

# Security
JWT_SECRET=super_secret_cyber_neon_key_replace_in_production
JWT_EXPIRES_IN=7d

# Initial Admin Credentials (Seeded on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword123

# Gemini API Key (Generate at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# DevFeed Destination API
# The endpoint where the bot will POST successfully curated news
DEVFEED_API_URL=http://deevfeed-news-backend.onrender.com/api/news
# Authorization header sent to DevFeed (optional)
DEVFEED_API_KEY=your_devfeed_api_key_here

# Bot Cron Configuration (Standard cron syntax)
# Default: Runs every 15 minutes (change to '*/1 * * * *' for testing every minute)
BOT_SYNC_INTERVAL=*/15 * * * *
